{
  // Self-contained (no "extends"): this package deploys standalone to
  // Vercel/Railway where ../../tsconfig.base.json is not uploaded.
  // Keep compilerOptions in sync with tsconfig.base.json at the repo root.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "jsx": "react-jsx",
    "noEmit": false
  },
  "include": ["src/**/*"]
}
