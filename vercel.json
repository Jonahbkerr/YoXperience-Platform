{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "name": "yoxperience-platform",
  "buildCommand": "npm run build:landing && npm run build:dashboard && cp -r packages/dashboard/dist packages/landing/dist/dashboard",
  "outputDirectory": "packages/landing/dist",
  "installCommand": "npm install",
  "routes": [
    {
      "src": "/dashboard/assets/(.*)",
      "dest": "/dashboard/assets/$1"
    },
    {
      "src": "/dashboard/(.*\\.(js|css|png|svg|ico|json|txt|xml))",
      "dest": "/dashboard/$1"
    },
    {
      "src": "/dashboard/(.*)",
      "dest": "/dashboard/index.html"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/auth/(.*)",
      "dest": "https://gateway-one-wheat.vercel.app/auth/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "https://gateway-one-wheat.vercel.app/api/$1"
    },
    {
      "src": "/v1/(.*)",
      "dest": "https://gateway-one-wheat.vercel.app/v1/$1"
    },
    {
      "src": "/health",
      "dest": "https://gateway-one-wheat.vercel.app/health"
    },
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    }
  ]
}
