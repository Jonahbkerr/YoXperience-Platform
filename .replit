modules = ["nodejs-20", "web", "bash"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx concurrently --names gateway,landing,dashboard \"npm run dev:gateway\" \"npm run dev:landing\" \"npm run dev:dashboard\""
waitForPort = 5173

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3457
externalPort = 3000

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5174
externalPort = 3002

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd /home/runner/workspace && NODE_ENV=production npx tsx packages/gateway/src/index.ts"]
build = ["bash", "-c", "cd /home/runner/workspace && npm -w @yoxperience/landing run build && npm -w @yoxperience/dashboard run build"]
