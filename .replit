modules = ["nodejs-20", "web"]

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npx concurrently --names gateway,landing,dashboard \"npm run dev:gateway\" \"npm run dev:landing\" \"npm run dev:dashboard\""
waitForPort = 5000

[[ports]]
localPort = 3457
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3003

[[ports]]
localPort = 5002
externalPort = 5000

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 5174
externalPort = 3002

[[ports]]
localPort = 5175
externalPort = 3001

[[ports]]
localPort = 5176
externalPort = 4200

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "GATEWAY_PORT=5000 NODE_ENV=production npx tsx packages/gateway/src/index.ts"]
build = ["bash", "-c", "cd /home/runner/workspace && npm -w @yoxperience/landing run build && npm -w @yoxperience/dashboard run build"]

[agent]
expertMode = true

[userenv]

[userenv.shared]
JWT_SECRET = "04d7ade61e4fef54c4137eb59cdad9668cd59cb398c5bd4590ef0d184c62494c"
GATEWAY_PORT = "3457"
CORS_ORIGINS = "http://0.0.0.0:5000,http://localhost:5000"
